import tkinter as tk
from tkinter import ttk, messagebox
import json
import os
from datetime import datetime


DATA_FILE = "weather_data.json"


def load_data():
    if os.path.exists(DATA_FILE):
        with open(DATA_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    return []

def save_data(data):
    with open(DATA_FILE, 'w', encoding='utf-8') as f:
        json.dump(data, f, ensure_ascii=False, indent=2)


class WeatherDiaryApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Дневник погоды")
        self.root.geometry("650x500")
        self.root.resizable(False, False)

        self.data = load_data()
        self.displayed_data = self.data.copy()

       
        input_frame = ttk.LabelFrame(root, text="Добавить новую запись", padding="10")
        input_frame.pack(pady=10, padx=10, fill='x')

    
        ttk.Label(input_frame, text="Дата (ГГГГ-ММ-ДД):").grid(row=0, column=0, sticky='w', pady=2)
        self.date_entry = ttk.Entry(input_frame, width=15)
        self.date_entry.grid(row=0, column=1, sticky='w', pady=2)

      
        ttk.Label(input_frame, text="Температура (°C):").grid(row=1, column=0, sticky='w', pady=2)
        self.temp_entry = ttk.Entry(input_frame, width=15)
        self.temp_entry.grid(row=1, column=1, sticky='w', pady=2)

        
        ttk.Label(input_frame, text="Описание:").grid(row=2, column=0, sticky='nw', pady=2)
        self.desc_entry = ttk.Entry(input_frame, width=30)
        self.desc_entry.grid(row=2, column=1, columnspan=2, sticky='we', pady=2)

       
        ttk.Label(input_frame, text="Осадки:").grid(row=3, column=0, sticky='w', pady=2)
        self.rain_var = tk.StringVar(value="Нет")
        ttk.OptionMenu(input_frame, self.rain_var, "Да", "Нет").grid(row=3, column=1, sticky='w', pady=2)

     
        ttk.Button(input_frame, text="Добавить запись", command=self.add_record).grid(row=4, column=0, columnspan=2, pady=10)

        
        filter_frame = ttk.LabelFrame(root, text="Фильтр", padding="10")
        filter_frame.pack(pady=10, padx=10, fill='x')

     
        ttk.Label(filter_frame, text="Дата:").grid(row=0, column=0, sticky='w')
        self.filter_date = ttk.Entry(filter_frame, width=15)
        self.filter_date.grid(row=0, column=1, sticky='w')

       
        ttk.Label(filter_frame, text="Температура выше (°C):").grid(row=1, column=0, sticky='w')
        self.filter_temp = ttk.Entry(filter_frame, width=15)
        self.filter_temp.grid(row=1, column=1, sticky='w')

        ttk.Button(filter_frame, text="Применить фильтр", command=self.apply_filter).grid(row=2, column=0, columnspan=2, pady=5)
        ttk.Button(filter_frame, text="Сбросить фильтр", command=self.reset_filter).grid(row=3, column=0, columnspan=2)

    
        table_frame = ttk.Frame(root)
        table_frame.pack(pady=10, padx=10, fill='both', expand=True)

        self.tree = ttk.Treeview(table_frame, columns=("date", "temp", "desc", "rain"), show='headings')
        self.tree.heading("date", text="Дата")
        self.tree.heading("temp", text="Температура")
        self.tree.heading("desc", text="Описание")
        self.tree.heading("rain", text="Осадки")
        
        self.tree.column("date", width=120)
        self.tree.column("temp", width=100)
        self.tree.column("desc", width=250)
        self.tree.column("rain", width=80)
        
        self.tree.pack(side='left', fill='both', expand=True)
        
        scrollbar = ttk.Scrollbar(table_frame, orient="vertical", command=self.tree.yview)
        scrollbar.pack(side='right', fill='y')
        
        self.tree.configure(yscrollcommand=scrollbar.set)
        
        self.update_table()

    def add_record(self):
        date = self.date_entry.get().strip()
        temp = self.temp_entry.get().strip()
        desc = self.desc_entry.get().strip()
        rain = self.rain_var.get()

         
         try:
            datetime.strptime(date, '%Y-%m-%d')
         except ValueError:
            messagebox.showerror("Ошибка", "Неверный формат даты. Используйте ГГГГ-ММ-ДД (например: 2024-04-29)")
            return

       
         try:
            temp_float = float(temp)
         except ValueError:
            messagebox.showerror("Ошибка", "Температура должна быть числом.")
            return

         
         if not desc:
            messagebox.showerror("Ошибка", "Описание не может быть пустым.")
            return

       
         record = {"date": date, "temp": temp_float, "desc": desc, "rain": rain}
         self.data.append(record)
         save_data(self.data)
         
        
         self.displayed_data = self.data.copy()  # Сброс фильтра после добавления
         self.update_table()
         
        
         self.date_entry.delete(0, tk.END)
         self.temp_entry.delete(0, tk.END)
         self.desc_entry.delete(0, tk.END)
         messagebox.showinfo("Успех", "Запись успешно добавлена!")

    def apply_filter(self):
         filter_date = self.filter_date.get().strip()
         filter_temp_str = self.filter_temp.get().strip()
         
         filtered_data = self.data.copy()
         
         if filter_date:
             filtered_data = [r for r in filtered_data if r["date"] == filter_date]
         
         if filter_temp_str:
             try:
                 temp_val = float(filter_temp_str)
                 filtered_data = [r for r in filtered_data if r["temp"] > temp_val]
             except ValueError:
                 messagebox.showerror("Ошибка", "В фильтре температуры должно быть число.")
                 return

         self.displayed_data = filtered_data
         self.update_table()

    def reset_filter(self):
         self.displayed_data = self.data.copy()
         self.filter_date.delete(0, tk.END)
         self.filter_temp.delete(0, tk.END)
         self.update_table()

    def update_table(self):
         for i in self.tree.get_children():
             self.tree.delete(i)
         
         for record in self.displayed_data:
             self.tree.insert("", "end", values=(record["date"], f"{record['temp']}°C", record["desc"], record["rain"]))


if __name__ == "__main__":
    root = tk.Tk()
    app = WeatherDiaryApp(root)
    root.mainloop()
